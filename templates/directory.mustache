{{!
    @template mod_iearchy/directory
}}
<div class="mod-iearchy" data-region="mod-iearchy">
    <header class="iearch_header">
        <span class="iearch_header__eyebrow">{{header_eyebrow}}</span>
        <h1 class="iearch_header__title">{{header_title}}</h1>
        <div class="iearch_header__line"></div>
    </header>

    {{#haslevels}}
        <div class="iearch_wrapper">
            {{#levels}}
                <section class="iearch_level" data-level="{{level}}">
                    <div class="iearch_level__decor"></div>
                    <div class="iearch_level__header">
                        <div class="iearch_level__label">{{eyebrow}}</div>
                        <h2 class="iearch_level__title">{{title}}</h2>
                    </div>

                    <div class="iearch_grid">
                        {{#employees}}
                            <article
                                class="iearch_card"
                                role="button"
                                tabindex="0"
                                aria-label="{{cardaria}}"
                                aria-haspopup="dialog"
                                aria-controls="iearchModal"
                                title="{{openprofile}}"
                                data-fullname="{{fullname}}"
                                data-position="{{position}}"
                                data-image-url="{{imageurl}}"
                                data-initials="{{initials}}"
                                data-has-image="{{#hasimage}}true{{/hasimage}}{{^hasimage}}false{{/hasimage}}"
                            >
                                <div class="iearch_card__img-wrap">
                                    {{#hasimage}}
                                        <img src="{{imageurl}}" class="iearch_card__img" alt="{{fullname}}" loading="lazy">
                                    {{/hasimage}}
                                    {{^hasimage}}
                                        <div class="iearch_card__img-placeholder">{{initials}}</div>
                                    {{/hasimage}}
                                </div>

                                <div class="iearch_card__info">
                                    <h3 class="iearch_card__name">{{fullname}}</h3>
                                    <p class="iearch_card__position">{{position}}</p>
                                    <div class="iearch_card__desc" hidden>{{description}}</div>
                                    
                                    <div class="iearch_card__arrow">
                                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
                                    </div>
                                </div>
                            </article>
                        {{/employees}}
                    </div>
                </section>
            {{/levels}}
        </div>
    {{/haslevels}}

    {{^haslevels}}
        <div class="iearch_empty">
            <div class="iearch_empty__icon">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M12 8v4"></path><path d="M12 16h.01"></path></svg>
            </div>
            <p>{{directoryempty}}</p>
        </div>
    {{/haslevels}}

    {{#canmanage}}
        <nav class="mod-iearchy__tools" aria-label="{{header_title}}">
            <a class="mod-iearchy__tool" href="{{managelevelsurl}}">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20V10"></path><path d="M18 20V4"></path><path d="M6 20v-4"></path></svg>
                {{managelevelslabel}}
            </a>
            <a class="mod-iearchy__tool" href="{{manageemployeesurl}}">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                {{manageemployeeslabel}}
            </a>
        </nav>
    {{/canmanage}}

    <div class="iearch_overlay" id="iearchOverlay" role="dialog" aria-modal="true" aria-labelledby="iearchModalName" aria-hidden="true">
        <div class="iearch_modal" id="iearchModal">
            <div class="iearch_modal__band"></div>
            <button class="iearch_modal__close" id="iearchClose" aria-label="{{close}}" type="button">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
            <div class="iearch_modal__body">
                <div class="iearch_modal__img-wrap" id="iearchModalImgWrap">
                    <div class="iearch_modal__img-placeholder">?</div>
                </div>
                <div class="iearch_modal__content">
                    <h2 class="iearch_modal__name" id="iearchModalName"></h2>
                    <p class="iearch_modal__position" id="iearchModalPosition"></p>
                    <div class="iearch_modal__divider"></div>
                    <div class="iearch_modal__desc-wrap">
                        <p class="iearch_modal__desc" id="iearchModalDesc"></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
